<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Registration - Premium Travel</title>
    <link rel="stylesheet" href="/stylesheets/premium.css">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }
        .registration-container {
            width: 100%;
            max-width: 450px;
        }
    </style>
</head>

<body>
    <div class="registration-container">
        <div class="form-premium fade-in">
            <h1 class="premium-title" style="font-size: 2.5rem; margin-bottom: 2rem;">Create Account</h1>
            <% if (error) { %>
                <div class="alert alert-danger-premium mb-4" role="alert">
                    <%= error %>
                </div>
            <% } %>
            <form method='post' action='/register'>
                <div class="form-group mb-4">
                    <label for="username" class="premium-label">Username</label>
                    <input type="text" class="form-control form-control-premium" id="username" name="username" placeholder="Choose a username" required>
                </div>
                <div class="form-group mb-4">
                    <label for="password" class="premium-label">Password</label>
                    <input type="password" class="form-control form-control-premium" id="password" name="password" placeholder="Choose a password" required>
                </div>
                <button type="submit" class="btn btn-premium btn-block mb-3">Register</button>
                <div class="text-center">
                    <a href="/login" class="premium-link">Already have an account? Login here</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
