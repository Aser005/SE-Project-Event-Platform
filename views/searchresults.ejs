<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Search Results - Premium Travel</title>
    <link rel="stylesheet" href="/stylesheets/premium.css">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-premium">
        <a class="navbar-brand" href="/home">Premium Travel</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <a class="nav-link premium-link" href="/home">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link premium-link" href="/wanttogo">My List</a>
                </li>
            </ul>
            <form method="POST" action='/search' class="form-inline my-2 my-lg-0">
                <input class="form-control search-premium mr-sm-2" name="Search" type="search" placeholder="Search destinations..."
                    aria-label="Search" value="<%= searchTerm || '' %>">
                <button class="btn btn-premium-outline my-2 my-sm-0" type="submit">Search</button>
            </form>
            <div class="ml-3">
                <span class="text-purple mr-3">Welcome, <%= user.username %></span>
                <a href="/logout" class="btn btn-premium-outline btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container-premium fade-in">
        <h1 class="premium-title">Search Results</h1>
        <% if (searchTerm) { %>
            <p class="text-center text-muted mb-5" style="font-size: 1.2rem;">Results for "<%= searchTerm %>"</p>
        <% } %>
        
        <div class="search-results">
            <% if (results && results.length > 0) { %>
                <% results.forEach(function(dest) { 
                    let url = '';
                    if (dest.name === 'Paris') url = '/paris';
                    else if (dest.name === 'Rome') url = '/rome';
                    else if (dest.name === 'Bali Island') url = '/bali';
                    else if (dest.name === 'Santorini Island') url = '/santorini';
                    else if (dest.name === 'Inca Trail to Machu Picchu') url = '/inca';
                    else if (dest.name === 'Annapurna Circuit') url = '/annapurna';
                %>
                    <div class="search-result-item" onclick="location.href='<%= url %>'">
                        <div class="row align-items-center">
                            <div class="col-md-3">
                                <img src="<%= dest.image %>" alt="<%= dest.name %>" style="width: 100%; max-width: 200px; border-radius: 12px; border: 2px solid var(--primary-purple);">
                            </div>
                            <div class="col-md-9">
                                <h3 class="text-purple mb-2"><%= dest.name %></h3>
                                <p class="text-muted mb-2"><strong>Category:</strong> <%= dest.category %></p>
                                <p class="text-secondary"><%= dest.description %></p>
                                <a href="<%= url %>" class="btn btn-premium-outline btn-sm mt-2">View Details</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state">
                    <h2>Destination not Found</h2>
                    <p>No destinations found matching your search. Try searching for a different destination or browse our categories.</p>
                    <a href="/home" class="btn btn-premium mt-4">Browse Destinations</a>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
    <script src="/javascripts/autocomplete.js"></script>
</body>
</html>
