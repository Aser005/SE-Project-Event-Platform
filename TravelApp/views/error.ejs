<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Error - Premium Travel</title>
    <link rel="stylesheet" href="/stylesheets/premium.css">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>

<body>
    <div class="container-premium" style="min-height: 100vh; display: flex; align-items: center; justify-content: center;">
        <div class="text-center fade-in">
            <h1 class="premium-title" style="font-size: 6rem; margin-bottom: 1rem;"><%= error.status || '500' %></h1>
            <h2 class="premium-subtitle mb-4"><%= message || 'Something went wrong' %></h2>
            <p class="text-muted mb-5" style="font-size: 1.2rem;">
                We're sorry, but something unexpected happened. Please try again later.
            </p>
            <div>
                <a href="/home" class="btn btn-premium mr-3">Go Home</a>
                <a href="javascript:history.back()" class="btn btn-premium-outline">Go Back</a>
            </div>
            <% if (typeof error !== 'undefined' && error.stack && process.env.NODE_ENV === 'development') { %>
                <div class="mt-5 p-4" style="background: rgba(26, 26, 46, 0.6); border-radius: 15px; text-align: left; max-width: 800px; margin: 0 auto;">
                    <h3 class="text-purple mb-3">Error Details (Development Only)</h3>
                    <pre style="color: var(--text-muted); font-size: 0.9rem; overflow-x: auto;"><%= error.stack %></pre>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
